# Routes
# https://www.playframework.com/documentation/latest/ScalaRouting

GET  /                              controllers.MainController.intro()
POST /changeCall                    controllers.MainController.changeCall(call: Int, redir: String)

GET  /login                         controllers.AuthController.login(path: Option[String])
POST /authenticate                  controllers.AuthController.authenticate()
GET  /logout                        controllers.AuthController.logout()
GET  /init_password                 controllers.AuthController.showInitPassword()
POST /init_password                 controllers.AuthController.initPassword()
GET  /reset_password                controllers.AuthController.showResetPassword(token: String)
POST /reset_password                controllers.AuthController.resetPassword()

GET  /add                           controllers.RefereeController.showAdd()
POST /add                           controllers.RefereeController.add()
GET  /requests                      controllers.RefereeController.list()
POST /sendRequestEmails             controllers.RefereeController.sendRequestEmails()
POST /sendRequestReminderEmails     controllers.RefereeController.sendRequestReminderEmails()

# Token-authed referee endpoints — the URL token *is* the credential, so CSRF
# does not apply. Marked with the route-level @nocsrf annotation.
+ nocsrf
GET  /submit                        controllers.RefereeController.showSubmit(token: String)
+ nocsrf
POST /submit                        controllers.RefereeController.submit()
+ nocsrf
GET  /lettert                       controllers.RefereeController.getLetterByToken(token: String)

GET  /letter                        controllers.RefereeController.getLetter(id: Long, email: String)

# JSON / bearer-authed API. CSRF is not applicable; auth is via the
# `Authorization: Bearer ...` header (ApiAuthAction).
+ nocsrf
POST /api/sendRequestEmails         controllers.RefereeController.apiSendRequestEmails(call: String)
+ nocsrf
POST /api/sendRequestReminderEmails controllers.RefereeController.apiSendRequestReminderEmails(call: String)
+ nocsrf
POST /api/dossiers/bulk             controllers.ImportController.apiBulk()

# Importer UI for committee members (session-authed, CSRF on).
GET  /import                        controllers.ImportController.index()
POST /import/run                    controllers.ImportController.runImporter(name: String)
POST /import/csv                    controllers.ImportController.uploadCsv()

# Static assets.
GET  /assets/*file                  controllers.Assets.versioned(path="/public", file: Asset)
